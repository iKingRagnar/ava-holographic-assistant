# Copia a .env.local para desarrollo local con Vercel CLI (no subir secretos al repo).
# En producción: Vercel → Settings → Environment Variables

# Base64 Basic de Inworld (Authorization: Basic …) — TTS y chat fallback
INWORLD_API_KEY=

# Opcional: Ollama local para /api/chat antes de Inworld
OLLAMA_URL=http://127.0.0.1:11434
