# Copia a .env.local para desarrollo local con Vercel CLI (no subir secretos al repo).
# En producción: Vercel → Settings → Environment Variables

# REQUERIDO: al menos uno — Claude, OpenAI, Gemini, DeepSeek o Groq
ANTHROPIC_API_KEY=sk-ant-api03-...
OPENAI_API_KEY=
GEMINI_API_KEY=

# STT / TTS
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=

# Opcional: noticias (gratis con registro)
NEWSDATA_API_KEY=

# Opcional: Inworld TTS (legacy)
INWORLD_API_KEY=

# Contexto horario en system prompt (api/chat.js) — IANA, ej. America/Monterrey
AVA_TIMEZONE=America/Mexico_City
# AVA_SKIP_MOTIVATION=1  # desactiva micro-frases motivacionales aleatorias
