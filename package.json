{
  "name": "ava-holographic-assistant",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "AVA holográfica — server Node + Three.js/VRM, deploy en Railway.",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "dev:static": "npx --yes serve . -l 3333",
    "dev:local": "node server.js",
    "deploy": "railway up",
    "deploy:vercel": "vercel --prod",
    "check:syntax": "node scripts/check-inline-js.mjs && node --check server.js && node --check api/chat.js",
    "test": "playwright test",
    "dev:vite":   "vite",
    "build:vite": "vite build",
    "upload:vrms": "node scripts/upload-vrms.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "ioredis": "^5.4.1",
    "pg": "^8.12.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "vercel": "latest"
  }
}
