{
  "version": 2,
  "public": true,
  "github": {
    "enabled": false
  },
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "ava.html",
      "use": "@vercel/static"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/:file.vrm",
      "destination": "/public/:file.vrm"
    },
    {
      "source": "/three-vrm-0.6.11.js",
      "destination": "/public/three-vrm-0.6.11.js"
    },
    {
      "source": "/(.*)",
      "destination": "/ava.html"
    }
  ]
}
